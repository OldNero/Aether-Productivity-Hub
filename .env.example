# Aether Hub Local Configuration
# Copy this file to .env and fill in your keys

# --- Supabase (Mandatory for Google Login & Cloud Sync) ---
# Find these in Supabase Dashboard > Settings > API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# --- API Keys (Optional but recommended) ---
# API Ninjas: https://api-ninjas.com/ (For quotes & insights)
NINJA_API_KEY=LOCAL_DEV_PLACEHOLDER

# Alpha Vantage: https://www.alphavantage.co/ (For stock data)
ALPHA_VANTAGE_KEY=LOCAL_DEV_PLACEHOLDER
