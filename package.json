{
  "scripts": {
    "dev": "node scripts/build.js && npx http-server dist -p 8080 -c-1",
    "dev:watch": "node scripts/generate-config.js && tailwindcss -i ./css/input.css -o ./css/output.css --watch",
    "build": "node scripts/build.js",
    "build:css": "tailwindcss -i ./css/input.css -o ./css/output.css --minify",
    "watch:css": "tailwindcss -i ./css/input.css -o ./css/output.css --watch"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.2",
    "autoprefixer": "^10.4.27",
    "eslint": "^8.57.1",
    "postcss": "^8.5.9",
    "prettier": "^2.8.8",
    "tailwindcss": "^4.2.2"
  },
  "dependencies": {
    "context-mode": "^1.0.75"
  }
}
